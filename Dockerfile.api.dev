FROM rust:1-bookworm AS builder
WORKDIR /build
COPY Cargo.toml Cargo.lock ./
COPY lb ./lb
COPY api ./api
RUN cargo build --release --bin api --bin preprocess

COPY resources ./resources
RUN ./target/release/preprocess resources/references.json.gz

FROM debian:bookworm-slim AS runtime
WORKDIR /app
COPY --from=builder /build/target/release/api /app/api
COPY --from=builder /build/out /app/out
ENV PORT=9999
EXPOSE 9999
CMD ["/app/api"]
